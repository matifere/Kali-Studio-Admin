# Copiá este archivo como .env y completá con tus credenciales reales.
# NUNCA comitees el archivo .env con valores reales.
#
# Para builds web, NO uses .env — inyectá las variables en build-time:
#   flutter build web \
#     --dart-define=SUPABASE_URL=https://TU_PROYECTO.supabase.co \
#     --dart-define=SUPABASE_ANON=sb_publishable_TU_CLAVE
#
# Para desarrollo local en web (flutter run):
#   flutter run -d chrome \
#     --dart-define=SUPABASE_URL=https://TU_PROYECTO.supabase.co \
#     --dart-define=SUPABASE_ANON=sb_publishable_TU_CLAVE

URL='https://TU_PROYECTO.supabase.co'
ANON='sb_publishable_TU_CLAVE_ANON'
VAPID_PUBLIC_KEY='TU_VAPID_PUBLIC_KEY'
